{
  "family": "jko-healthcheck",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "256",
  "memory": "512",
  "runtimePlatform": {
    "cpuArchitecture": "X86_64",
    "operatingSystemFamily": "LINUX"
  },
  "executionRoleArn": "arn:aws:iam::REPLACE_ACCOUNT_ID:role/jko_ecs",
  "containerDefinitions": [
    {
      "name": "jko-healthcheck",
      "image": "REPLACE_ON_DEPLOY",
      "essential": true,
      "portMappings": [
        {
          "containerPort": 8080,
          "protocol": "tcp"
        }
      ],
      "environment": [
        { "name": "POSTGRES_HOST", "value": "REPLACE_EC2_PRIVATE_IP" },
        { "name": "POSTGRES_PORT", "value": "5432" },
        { "name": "POSTGRES_USER", "value": "jko_vm" },
        { "name": "POSTGRES_DB", "value": "jko_donation" },
        { "name": "REDIS_HOST", "value": "REPLACE_EC2_PRIVATE_IP" },
        { "name": "REDIS_PORT", "value": "6379" }
      ],
      "secrets": [
        {
          "name": "POSTGRES_PASSWORD",
          "valueFrom": "arn:aws:secretsmanager:ap-southeast-2:REPLACE_ACCOUNT_ID:secret:jko_vm_pg_redis_1:POSTGRES_PASSWORD::"
        },
        {
          "name": "REDIS_PASSWORD",
          "valueFrom": "arn:aws:secretsmanager:ap-southeast-2:REPLACE_ACCOUNT_ID:secret:jko_vm_pg_redis_1:REDIS_PASSWORD::"
        }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/jko-healthcheck",
          "awslogs-region": "ap-southeast-2",
          "awslogs-stream-prefix": "ecs",
          "awslogs-create-group": "true"
        }
      }
    }
  ]
}
